    "style_guide": "Research explainer: emphasize fixed versus learned processes and keep particle clouds schematic.",
    "beats": [
      {
        "beat_id": "b00",
        "spoken_text": "DDPMs separate fixed forward corruption from learned iterative reverse denoising.",
        "teaching_intent": "intro",
        "visual_need": "Show the video title and closed-form q(x_t | x_0) formula.",
        "pacing_intent": "opening_hold",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b01",
        "spoken_text": "A DDPM begins with a clean structured sample, x zero.",
        "teaching_intent": "setup",
        "visual_need": "Show a clean tile and a timestep rail at t=0.",
        "pacing_intent": "medium",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b02",
        "spoken_text": "The forward process is fixed: beta t schedules how much Gaussian noise is added.",
        "teaching_intent": "define_forward",
        "visual_need": "Diffuse the tile across a left-to-right timeline into a particle cloud.",
        "pacing_intent": "medium",
        "linked_prerequisites": ["gaussian_noise", "markov_chain"]
      },
      {
        "beat_id": "b03",
        "spoken_text": "The closed form uses alpha bar t to jump directly to a noisy state at any chosen timestep.",
        "teaching_intent": "formula_link",
        "visual_need": "Show signal-retention curve and slider tied to x_t.",
        "pacing_intent": "slow_reveal",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b04",
        "spoken_text": "Generation runs the learned reverse process repeatedly, moving from noise back toward structure.",
        "teaching_intent": "synthesis",
        "visual_need": "Route noisy states through epsilon_theta over several reverse ticks.",
        "pacing_intent": "payoff",
        "linked_prerequisites": ["learned_denoiser"]
      }
    ]
  },
