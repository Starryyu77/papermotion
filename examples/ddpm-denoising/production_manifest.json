    "scope": [
      "Clean state x_0",
      "Fixed forward noising schedule beta_t",
      "Closed-form x_t sampling with alpha_bar_t",
      "Learned iterative reverse denoising"
    ],
    "out_of_scope": [
      "Training loss derivation",
      "U-Net internals",
      "Classifier-free guidance",
      "Exact pixel-space generation"
    ]
  },
