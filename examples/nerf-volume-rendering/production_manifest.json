      }
    ]
  },
  "curriculum_plan": {
    "concept_order": [
      "one pixel one ray",
      "sample positions",
      "field query",
      "transmittance weighting",
      "many rays form view"
    ],
    "just_in_time_insertions": [
      {
        "concept_id": "continuous_field",
        "insert_before_beat": "b03",
        "one_sentence_explanation": "NeRF stores a learned function that can be queried at coordinates, not a fixed voxel table."
      },
      {
        "concept_id": "transmittance",
        "insert_before_beat": "b04",
        "one_sentence_explanation": "Transmittance is accumulated visibility: dense near samples reduce the influence of later samples."
      }
    ]
  },
  "script": {
    "style_guide": "Spatial research explainer: preserve near-to-far order and keep every formula deterministic.",
    "beats": [
      {
        "beat_id": "b00",
        "spoken_text": "NeRF volume rendering turns field queries along a camera ray into one pixel color.",
        "teaching_intent": "intro",
        "visual_need": "Show the video title and volume rendering equation.",
        "pacing_intent": "opening_hold",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b01",
        "spoken_text": "One camera pixel casts one ordered ray through the scene volume.",
        "teaching_intent": "setup",
        "visual_need": "Show camera, image-plane pixel, volume, ray r(t), and direction d.",
        "pacing_intent": "medium",
        "linked_prerequisites": ["camera_ray"]
      },
      {
        "beat_id": "b02",
        "spoken_text": "NeRF samples positions along that ray from near to far.",
        "teaching_intent": "sampling",
        "visual_need": "Reveal ordered sample beads along the ray.",
        "pacing_intent": "medium",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b03",
        "spoken_text": "Each sample queries a continuous field with position and viewing direction.",
        "teaching_intent": "field_query",
        "visual_need": "Route sample beads into F_Theta and show sigma/color outputs.",
        "pacing_intent": "slow_reveal",
        "linked_prerequisites": ["continuous_field"]
      },
      {
        "beat_id": "b04",
        "spoken_text": "The rendered pixel is a transmittance-weighted accumulation of those color contributions.",
        "teaching_intent": "integration",
        "visual_need": "Show fading visibility ribbon and weighted color aggregation into C(r).",
        "pacing_intent": "slow_down",
        "linked_prerequisites": ["transmittance"]
      },
      {
        "beat_id": "b05",
        "spoken_text": "A full image repeats the same process over many camera rays.",
        "teaching_intent": "synthesis",
        "visual_need": "Sweep additional rays from the camera plane.",
        "pacing_intent": "resolve",
        "linked_prerequisites": []
      }
    ]
  },
