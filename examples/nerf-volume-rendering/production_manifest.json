{
  "project": {
    "demo_id": "nerf-volume-rendering",
    "title": "NeRF Volume Rendering Along a Ray",
    "source_type": "paper_excerpt",
    "status": "full_video_rendered",
    "owner": "PaperMotion"
  },
  "intent": {
    "viewer_goal": "Understand how NeRF turns field queries along a camera ray into a rendered pixel.",
    "target_audience": "Graduate students or researchers who have seen the NeRF rendering equation but need spatial mechanism intuition.",
    "learning_objective": "After watching, the viewer should be able to explain ray sampling, F_Theta(x,d), density/color outputs, transmittance, and pixel accumulation.",
    "scope": [
      "One camera ray for one pixel",
      "Ordered samples along the ray",
      "Continuous field query F_Theta(x,d)",
      "Density, color, and transmittance-weighted integration",
      "Many-ray sweep as the bridge to a full view"
    ],
    "out_of_scope": [
      "Training loss",
      "Pose optimization",
      "Hierarchical sampling details",
      "Full image synthesis implementation"
    ]
  },
