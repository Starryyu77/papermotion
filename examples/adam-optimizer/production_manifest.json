  "intent": {
    "viewer_goal": "Understand how Adam turns noisy gradients into adaptive update steps.",
    "target_audience": "Graduate machine-learning students who know stochastic gradient descent but want mechanism-level intuition for Adam.",
    "learning_objective": "After watching, the viewer should be able to explain how first and second moment estimates combine to produce Adam's adaptive parameter step.",
    "scope": [
      "Stochastic gradient sampling",
      "First moment smoothing",
      "Second moment squared-gradient scale",
      "Adaptive update step"
    ],
    "out_of_scope": [
      "Full convergence theory",
      "Bias-correction derivation details",
      "Real high-dimensional optimizer trajectories"
    ]
  },
