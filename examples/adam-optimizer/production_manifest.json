      {
        "concept_id": "exponential_average",
        "insert_before_beat": "b02",
        "one_sentence_explanation": "An exponential moving average keeps a memory of previous gradients while still reacting to the current one."
      },
      {
        "concept_id": "coordinate_scale",
        "insert_before_beat": "b03",
        "one_sentence_explanation": "Squared-gradient scale is used to damp directions whose gradients have been large or unstable."
      }
    ]
  },
  "script": {
    "style_guide": "Research explainer: precise formulas, calm pacing, no claims beyond the toy teaching slice.",
    "beats": [
      {
        "beat_id": "b00",
        "spoken_text": "Adam combines noisy gradients, moment estimates, and adaptive scaling into one update rule.",
        "teaching_intent": "intro",
        "visual_need": "Show the video title and final Adam update formula.",
        "pacing_intent": "opening_hold",
        "linked_prerequisites": []
      },
      {
        "beat_id": "b01",
        "spoken_text": "Adam starts with the same raw material as SGD: a noisy stochastic gradient at the current parameter point.",
        "teaching_intent": "setup",
        "visual_need": "Show theta_t on a teaching loss slice and reveal several red gradient arrows.",
        "pacing_intent": "medium",
        "linked_prerequisites": ["stochastic_gradient"]
      },
      {
        "beat_id": "b02",
        "spoken_text": "The first moment smooths those noisy gradients into a steadier direction estimate.",
        "teaching_intent": "transform",
        "visual_need": "Transform raw red gradients into a stable blue first-moment arrow.",
        "pacing_intent": "slow_reveal",
        "linked_prerequisites": ["exponential_average"]
      },
      {
        "beat_id": "b03",
        "spoken_text": "The second moment tracks squared-gradient scale, not curvature.",
        "teaching_intent": "misconception_guardrail",
        "visual_need": "Show purple scale halos with explicit squared-gradient wording.",
        "pacing_intent": "slow_down",
        "linked_prerequisites": ["coordinate_scale"]
      },
      {
        "beat_id": "b04",
        "spoken_text": "The final Adam step divides the smoothed direction by that scale and moves the parameters.",
        "teaching_intent": "synthesis",
        "visual_need": "Route blue direction through purple scale into a green adaptive step.",
        "pacing_intent": "payoff",
        "linked_prerequisites": []
      }
    ]
  },
