# PaperMotion local configuration

PAPERMOTION_OUTPUT_ROOT=examples
PAPERMOTION_DEFAULT_RENDER_QUALITY=low

# Optional provider keys. Keep real values in .env.local only.
OPENAI_API_KEY=
PIXVERSE_API_KEY=
RUNWAY_API_KEY=
VEO_API_KEY=

# Optional renderer flags.
PAPERMOTION_ENABLE_AI_VIDEO=0
PAPERMOTION_ENABLE_MANIM=1
PAPERMOTION_ENABLE_REMOTION=0
PAPERMOTION_ENABLE_BLENDER=0
