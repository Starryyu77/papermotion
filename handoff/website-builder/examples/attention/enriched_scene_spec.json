    {
      "scene_id": "s03",
      "title": "Similarity Heatmap",
      "linked_beats": ["b03", "b04"],
      "timestamp_start_s": 17,
      "duration_s": 16,
      "narration": "The query compares itself with every key. These comparisons become a grid of relevance scores. Dividing by the square root of the key dimension keeps the scores from becoming too extreme too early.",
      "narration_duration_s": 14.7,
      "pacing": "slow_down",
      "insight_moment": true,
      "wait_after_s": 0.6,
      "visual_type": "hybrid",
      "manim": {
        "scene_class": "SimilarityHeatmap",
        "camera_type": "MovingCameraScene",
        "camera_action": "push from query-key comparison into score grid",
        "objects": [
          {
            "id": "formula_qkt",
            "type": "MathTex",
            "content": "QK^T",
            "color": "score_color"
          },
          {
            "id": "query_vector_cards",
            "type": "VGroup",
            "content": "three query vector cards",
            "color": "query_color"
          },
          {
            "id": "key_vector_cards",
            "type": "VGroup",
            "content": "four key vector cards",
            "color": "key_color"
          },
          {
            "id": "attention_heatmap",
            "type": "MatrixGrid",
            "content": "3 by 4 score grid",
            "color": "score_color"
          },
          {
            "id": "scale_term",
            "type": "MathTex",
            "content": "\\\\frac{QK^T}{\\\\sqrt{d_k}}",
            "color": "scale_color"
          }
        ],
        "animation_sequence": [
          {
            "action": "Write",
            "target": "formula_qkt",
            "description": "Show QK^T above query and key cards.",
            "run_time": 2.0
          },
          {
            "action": "Create",
            "target": "comparison_lines",
            "description": "Draw comparisons from one query to every key.",
            "run_time": 4.0
          },
          {
            "action": "FadeIn",
            "target": "attention_heatmap",
            "description": "Populate the full heatmap row by row.",
            "run_time": 2.0
          },
          {
            "action": "Indicate",
            "target": "sharp_scores",
            "description": "Pulse over-sharp cells before scaling.",
            "run_time": 4.0
          },
          {
            "action": "TransformMatchingTex",
            "target": "scale_term",
            "description": "Transform QK^T into QK^T divided by sqrt(d_k) and soften the heatmap.",
            "run_time": 4.0
          }
        ],
        "render": {
          "transparent_background": true,
          "output_path": "site/public/videos/scenes/s03_similarity_heatmap.webm"
        }
      },
