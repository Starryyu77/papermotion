    {
      "scene_id": "s01",
      "title": "Tokens Ask For Context",
      "linked_beats": ["b01"],
      "timestamp_start_s": 0,
      "duration_s": 7,
      "narration": "A token does not look at a sentence all at once. It asks a more local question: which other tokens matter to me right now?",
      "narration_duration_s": 6.2,
      "pacing": "medium",
      "insight_moment": false,
      "wait_after_s": 0.4,
      "visual_type": "hybrid",
      "manim": {
        "scene_class": "TokensAskForContext",
        "camera_type": "Scene",
        "camera_action": "static wide sentence strip",
        "objects": [
          {
            "id": "sentence_tokens",
            "type": "VGroup",
            "content": "token tiles in a sentence strip",
            "color": "text_color"
          },
          {
            "id": "active_token",
            "type": "RoundedRectangle",
            "content": "highlighted current token",
            "color": "query_color"
          }
        ],
        "animation_sequence": [
          {
            "action": "FadeIn",
            "target": "sentence_tokens",
            "description": "Reveal the sentence as separate token tiles.",
            "run_time": 1.5
          },
          {
            "action": "Indicate",
            "target": "active_token",
            "description": "Highlight one token as the query source.",
            "run_time": 1.2
          },
          {
            "action": "Create",
            "target": "context_arcs",
            "description": "Draw soft arcs from the active token to relevant neighbors.",
            "run_time": 3.0
          }
        ],
        "render": {
          "transparent_background": true,
          "output_path": "site/public/videos/scenes/s01_tokens_context.webm"
        }
